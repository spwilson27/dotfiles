source_file() {
	[ -f $1 ] && source $1
}

source_file $HOME/.cargo/env
source_file $HOME/.env-secret
source_file $HOME/.local/share/fzf/fzf.sh

export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.pixi/bin:$PATH"
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"
export PATH="/home/mrwilson/.lmstudio/bin:$PATH"
export PATH="$HOME/.local/share/agents:$PATH"
export PATH="$HOME/.local/share/tmux-sessionizer:$PATH"

export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

